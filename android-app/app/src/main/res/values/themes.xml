<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AuraShieldAI" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (Electric Mint Green for safety). -->
        <item name="colorPrimary">@color/mint_green</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color (Neon Coral for alerts). -->
        <item name="colorSecondary">@color/neon_coral</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Background and Window settings. -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/midnight_navy_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.AuraShield" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        <item name="colorPrimary">@color/aura_mint</item>
        <item name="colorOnPrimary">@color/bg_void</item>
        <item name="colorSecondary">@color/accent_violet</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="fontFamily">sans-serif</item>
    </style>

    <style name="Text.Display" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="Text.Heading" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Body" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Text.Caption" parent="">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="Pill.Risk" parent="">
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
